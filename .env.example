# === Booking ===
# NexHealth booking URL (discover on first run with HEADLESS=false)
# Leave blank to auto-discover from aryaderm.com/appointments/
NEXHEALTH_BOOKING_URL=

# Provider names to look for (comma-separated, matched case-insensitively)
PROVIDER_NAMES=Forum Patel,Lavanya Krishnan

# Appointment type to select (substring match)
APPOINTMENT_TYPE=Established Patient

# === Schedule ===
# Check interval in minutes
CHECK_INTERVAL_MINUTES=15

# Run browser headless (set to false for first-run discovery)
HEADLESS=true

# === Notifications: Gmail ===
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
NOTIFY_EMAIL_TO=

# === Notifications: ntfy.sh (optional) ===
# Pick any unique topic name, subscribe to it in the ntfy app
NTFY_TOPIC=
